rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.super_admin == true
      );
    }

    function isTenantMember(tenantId) {
      return isAuthenticated() && request.auth.token.tenant_id == tenantId;
    }

    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) &&
             request.auth.token.role == 'tenant_admin';
    }

    function isTenantStaffAdmin(tenantId) {
      return isTenantMember(tenantId) &&
             (request.auth.token.role == 'tenant_admin' ||
              request.auth.token.role == 'staff_admin');
    }

    function isTenantStaff(tenantId) {
      return isTenantMember(tenantId) &&
             (request.auth.token.role == 'tenant_admin' ||
              request.auth.token.role == 'staff_admin' ||
              request.auth.token.role == 'staff');
    }

    function isStaffOrAbove() {
      return isAuthenticated() && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.role == 'tenant_admin' ||
        request.auth.token.role == 'staff_admin' ||
        request.auth.token.role == 'staff'
      );
    }

    // ─── Tenants ────────────────────────────────────────────────────────────
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || isTenantMember(tenantId);
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);

      // ─── Chores — staff_admin+ can write ──────────────────────────────────
      match /chores/{choreId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create, update, delete: if isSuperAdmin() || isTenantStaffAdmin(tenantId);
      }

      // ─── Incidents — staff can report, staff_admin+ can update/close ──────
      match /incidents/{incidentId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create: if isSuperAdmin() || isTenantStaff(tenantId);
        allow update: if isSuperAdmin() || isTenantStaffAdmin(tenantId);
        allow delete: if isSuperAdmin(); // incidents are permanent audit records
      }

      // ─── Rides — any tenant member can request, staff_admin+ can assign ───
      match /rides/{rideId} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow create: if isSuperAdmin() || isTenantMember(tenantId);
        allow update: if isSuperAdmin() || isTenantStaffAdmin(tenantId) ||
                        (isTenantMember(tenantId) &&
                         resource.data.requestedBy == request.auth.uid);
        allow delete: if isSuperAdmin();
      }

      // ─── Social posts — tenant staff and above can read/write; SuperAdmin can read all
      match /socialPosts/{postId} {
        allow read, write: if isSuperAdmin() || isTenantStaff(tenantId);
      }

      // ─── Social accounts — only tenant_admin+ can manage OAuth tokens
      match /socialAccounts/{accountId} {
        allow read: if isSuperAdmin() || isTenantStaff(tenantId);
        allow write: if isSuperAdmin() || isTenantAdmin(tenantId);
      }

      // ─── Admissions / Facility Applications ──────────────────────────────────
      // Public intake pipeline: any authenticated user (including role: 'user' /
      // 'applicant') can submit and read their own application. Status MUST be
      // 'pending_triage' on creation to prevent applicants from self-approving.
      match /applications/{appId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          isTenantStaff(tenantId) ||
          resource.data.applicantId == request.auth.uid
        );
        allow create: if isAuthenticated() &&
          request.resource.data.applicantId == request.auth.uid &&
          request.resource.data.status == 'pending_triage';
        allow update: if isSuperAdmin() || isTenantStaff(tenantId);
        allow delete: if isSuperAdmin();
      }

      // ─── All other tenant subcollections (houses, staff, events, vehicles, enrollments)
      match /{document=**} {
        allow read: if isSuperAdmin() || isTenantMember(tenantId);
        allow write: if isSuperAdmin() || isTenantStaffAdmin(tenantId);
      }
    }

    // ─── Residents (global — not tenant-scoped) ──────────────────────────────
    // Residents can exist independently and move between tenants, but their
    // resident record carries a `tenantId` field set at creation time.
    // Staff may only read/write residents belonging to their own tenant.
    // (API routes use Admin SDK and bypass these rules entirely.)
    match /residents/{residentId} {
      // Only staff of the *same* tenant may read resident PII; SuperAdmin reads all.
      allow read: if isSuperAdmin() ||
                     (isStaffOrAbove() &&
                      request.auth.token.tenant_id == resource.data.tenantId);
      // On create, the tenantId field must match the requester's own tenant.
      allow create: if isSuperAdmin() || (
        (request.auth.token.role == 'tenant_admin' ||
         request.auth.token.role == 'staff_admin') &&
        request.resource.data.tenantId == request.auth.token.tenant_id
      );
      // On update, the existing document must belong to the requester's tenant.
      allow update: if isSuperAdmin() || (
        (request.auth.token.role == 'tenant_admin' ||
         request.auth.token.role == 'staff_admin') &&
        resource.data.tenantId == request.auth.token.tenant_id
      );
      allow delete: if isSuperAdmin();

      // Personal resident events (appointments, drug tests, etc.)
      // Inherit tenant check from the parent resident document via get().
      match /events/{eventId} {
        allow read: if isSuperAdmin() ||
          (isStaffOrAbove() &&
           request.auth.token.tenant_id ==
             get(/databases/$(database)/documents/residents/$(residentId)).data.tenantId);
        allow create: if isSuperAdmin() ||
          (isStaffOrAbove() &&
           request.auth.token.tenant_id ==
             get(/databases/$(database)/documents/residents/$(residentId)).data.tenantId);
        allow update: if isSuperAdmin() || (
          (request.auth.token.role == 'tenant_admin' ||
           request.auth.token.role == 'staff_admin') &&
          request.auth.token.tenant_id ==
            get(/databases/$(database)/documents/residents/$(residentId)).data.tenantId
        );
        allow delete: if isSuperAdmin();
      }
    }

    // ─── App Users (mobile) ──────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isSuperAdmin();

      // LMS course enrollments — user owns their own; SuperAdmin can read all.
      // Progress writes are allowed client-side for offline tracking;
      // the API route (Admin SDK) is the authoritative writer for grading.
      match /courseEnrollments/{courseId} {
        allow read: if isAuthenticated() && (request.auth.uid == uid || isSuperAdmin());
        allow create: if isAuthenticated() && request.auth.uid == uid;
        allow update: if isAuthenticated() && request.auth.uid == uid;
        allow delete: if isSuperAdmin();
      }
    }

    // ─── Join Requests (resident applying to join a tenant) ──────────────────
    match /tenants/{tenantId}/joinRequests/{uid} {
      allow read: if isSuperAdmin() || isTenantStaffAdmin(tenantId);
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isSuperAdmin() || isTenantStaffAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantStaffAdmin(tenantId);
    }

    // ─── Universal Conversations (DM, Group, App Thread, AI Chat) ──────────────
    // Access is governed by the `participants` array (UIDs), not tenant nesting.
    // SuperAdmin has global read bypass for oversight.
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.uid in resource.data.participants
      );
      // Creator must include themselves in participants on create
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      // Any participant can update (e.g. update lastMessage, add participant)
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if isSuperAdmin();

      // Messages subcollection — gated on parent conversation participation
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
        );
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        // Only the sender can edit/delete their own message; SuperAdmin can delete any
        allow update: if isAuthenticated() && request.auth.uid == resource.data.senderId;
        allow delete: if isAuthenticated() && (
          isSuperAdmin() ||
          request.auth.uid == resource.data.senderId
        );
      }
    }

    // ─── Global LMS Courses ──────────────────────────────────────────────────
    // Courses can be public for all, or restricted to a specific tenant
    match /courses/{courseId} {
      allow read: if isAuthenticated() && (
        resource.data.isPublic == true ||
        resource.data.ownerTenantId == 'system' ||
        isTenantMember(resource.data.ownerTenantId)
      );
      allow create: if isSuperAdmin() || isTenantStaffAdmin(request.resource.data.ownerTenantId);
      allow update, delete: if isSuperAdmin() || isTenantStaffAdmin(resource.data.ownerTenantId);
      
      // Subcollections inside courses
      match /{document=**} {
         allow read: if isAuthenticated() && (
            get(/databases/$(database)/documents/courses/$(courseId)).data.isPublic == true ||
            get(/databases/$(database)/documents/courses/$(courseId)).data.ownerTenantId == 'system' ||
            isTenantMember(get(/databases/$(database)/documents/courses/$(courseId)).data.ownerTenantId)
         );
         allow write: if isSuperAdmin() || isTenantStaffAdmin(get(/databases/$(database)/documents/courses/$(courseId)).data.ownerTenantId);
      }
    }

    // ─── Gamification ────────────────────────────────────────────────────────
    // Global Leaderboard and Tenant Leaderboards
    match /gamification/{boardId} {
      // Anyone authenticated can read global or their tenant's points
      allow read: if isAuthenticated();
      
      // Points should only be incremented by secure Cloud Functions (or SuperAdmin)
      // We block client-side updates to prevent cheating
      allow write: if isSuperAdmin();
      
      match /profiles/{uid} {
         allow read: if isAuthenticated();
         // Clients cannot manually update their score
         allow write: if isSuperAdmin();
      }
    }

    // ─── Applications (global — all 5 types funnel through SuperAdmin) ──────────
    match /applications/{applicationId} {
      // Applicant can read their own; SuperAdmin can read all
      allow read: if isAuthenticated() && (
        resource.data.applicantId == request.auth.uid ||
        isSuperAdmin()
      );
      // Anyone can submit an application (public forms)
      allow create: if true;
      // Only SuperAdmin can update (assign, accept, reject)
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Notifications (inbox) ───────────────────────────────────────────────
    // Scoped by tenantId field. Tenant members read their org's notifications.
    // super_admin also reads notifications where tenantId == their uid
    // (self-scoped notifications created by Phase 5.2 routing).
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.tenantId == request.auth.token.tenant_id ||
        resource.data.tenantId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.tenantId == request.auth.token.tenant_id ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSuperAdmin();
      allow delete: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.tenantId == request.auth.token.tenant_id ||
        resource.data.tenantId == request.auth.uid
      );
    }

    // ─── Marketing templates (global, SuperAdmin-managed) ────────────────────
    match /marketingTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ─── QA Feedback ────────────────────────────────────────────────────────
    match /qa_feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin();
    }

    // ─── SuperAdmin global bypass ────────────────────────────────────────────
    // Belt-and-suspenders: any super_admin token can read/write any document.
    // Accepts both claim formats: role == 'super_admin' (server-set) and
    // super_admin == true (legacy boolean claim).
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.super_admin == true
      );
    }

    // ─── Deny all other access by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
