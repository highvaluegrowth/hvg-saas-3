{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "channel": "preview"
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "simulator": false
            },
            "channel": "production"
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./google-play-service-account.json",
                "track": "internal"
            },
            "ios": {
                "appleId": "FILL_IN_YOUR_APPLE_ID_EMAIL",
                "ascAppId": "FILL_IN_APP_STORE_CONNECT_APP_ID",
                "appleTeamId": "FILL_IN_APPLE_TEAM_ID"
            }
        }
    }
}